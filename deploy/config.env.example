# ============================================================
# CareConnect EHR — Deployment Configuration
# Copy this file to config.env and fill in your values
# ============================================================
# SSH access — used by deploy/deploy.sh to reach VM1 and VM2
SSH_USER=cisco
SSH_KEY=~/.ssh/id_rsa   # path to private key; leave blank to use ssh-agent

# VM Hostnames (already assigned — use your actual hostnames or IPs)
FRONTEND_HOST=careconnect-web.example.com
API_HOST=careconnect-api.example.com
DB_HOST=careconnect-db.example.com

# API base URL baked into the React bundle at build time.
# Leave empty (recommended) — Nginx on VM1 proxies /api/* → VM2 using the
# private IP, so the browser only ever talks to the same origin.
API_URL=

# Private IPs for firewall rules (use internal/private IPs within VPC/VNet)
FRONTEND_PRIVATE_IP=10.0.1.10
API_PRIVATE_IP=10.0.1.20
DB_PRIVATE_IP=10.0.1.30
MOCK_PRIVATE_IP=10.0.1.40

# Database credentials (use a strong password in production)
DB_NAME=careconnect
DB_USER=careconnect
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# JWT secret — generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_THIS_JWT_SECRET

# App version tag (used for deployment tracking)
APP_VERSION=1.0.0

# ── AI Assistant (Claude / Anthropic) ───────────────────────────
# Get your API key from: console.anthropic.com → API Keys
# Leave blank to disable the AI Assistant feature
ANTHROPIC_API_KEY=

# ── Splunk Observability Cloud ──────────────────────────────────
# Get these from: Splunk O11y Cloud → Settings → Access Tokens
# APM + Infrastructure token (type: INGEST)
SPLUNK_ACCESS_TOKEN=CHANGE_THIS_O11Y_ACCESS_TOKEN
# RUM-specific token (type: RUM) — separate from the ingest token
SPLUNK_RUM_TOKEN=CHANGE_THIS_RUM_TOKEN
# Your Splunk realm (visible in the O11y Cloud URL: app.REALM.signalfx.com)
SPLUNK_REALM=us1
# App environment label shown in Splunk APM service map
APP_ENV=production

# ── Splunk Platform (internal instance) ────────────────────────
# Logs are sent here instead of Observability Cloud
# HEC URL format: https://<your-splunk-host>:8088/services/collector/event
SPLUNK_PLATFORM_HEC_URL=https://splunk.internal.example.com:8088/services/collector/event
SPLUNK_PLATFORM_HEC_TOKEN=CHANGE_THIS_PLATFORM_HEC_TOKEN

# ── BFF (Backend for Frontend) — runs on VM1 alongside the frontend ────────────
# Port the BFF listens on (ALB /bff/* rule points to VM1:BFF_PORT)
BFF_PORT=3003

# ── Mock External Services VM (VM4) ────────────────────────────
# Private IP of VM4 — used by deploy.sh and firewall rules
# If co-locating mock on the API VM (VM2), use API_PRIVATE_IP and set MOCK_HOST=localhost in API .env
MOCK_PORT=3002

# Per-service simulated latency milliseconds — written to VM4 .env
# Designed to reflect real geographic distances between EHR and external SaaS
SURESCRIPTS_LATENCY_MS=180
SURESCRIPTS_LATENCY_JITTER=60
SURESCRIPTS_REGION="us-east-1 (Scottsdale, AZ)"

QUEST_LATENCY_MS=240
QUEST_LATENCY_JITTER=80
QUEST_REGION="us-east-1 (Secaucus, NJ)"

LABCORP_LATENCY_MS=310
LABCORP_LATENCY_JITTER=100
LABCORP_REGION="us-east-2 (Burlington, NC)"

TWILIO_LATENCY_MS=120
TWILIO_LATENCY_JITTER=40
TWILIO_REGION="us-west-2 (San Francisco, CA)"

SENDGRID_LATENCY_MS=95
SENDGRID_LATENCY_JITTER=30
SENDGRID_REGION="us-west-1 (Redwood City, CA)"

# ── Lab Result Simulator ────────────────────────────────────────
# Background job on VM2 that results pending lab orders with synthetic values.
# LAB_RESULT_INTERVAL_MS — how often the batch runs (default: 900000 = 15 min)
# LAB_MIN_AGE_MS         — minimum order age before it is resulted (default: same as interval)
# Set LAB_MIN_AGE_MS=60000 for a 1-minute turnaround during live demos.
LAB_RESULT_INTERVAL_MS=900000
LAB_MIN_AGE_MS=900000
