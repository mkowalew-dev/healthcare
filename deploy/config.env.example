# ============================================================
# CareConnect EHR — Deployment Configuration
# Copy this file to config.env and fill in your values
# ============================================================

# VM Hostnames (already assigned — use your actual hostnames or IPs)
FRONTEND_HOST=careconnect-web.example.com
API_HOST=careconnect-api.example.com
DB_HOST=careconnect-db.example.com

# Private IPs for firewall rules (use internal/private IPs within VPC/VNet)
FRONTEND_PRIVATE_IP=10.0.1.10
API_PRIVATE_IP=10.0.1.20
DB_PRIVATE_IP=10.0.1.30

# Database credentials (use a strong password in production)
DB_NAME=careconnect
DB_USER=careconnect
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# JWT secret — generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_THIS_JWT_SECRET

# App version tag (used for deployment tracking)
APP_VERSION=1.0.0

# ── AI Assistant (Claude / Anthropic) ───────────────────────────
# Get your API key from: console.anthropic.com → API Keys
# Leave blank to disable the AI Assistant feature
ANTHROPIC_API_KEY=

# ── Splunk Observability Cloud ──────────────────────────────────
# Get these from: Splunk O11y Cloud → Settings → Access Tokens
# APM + Infrastructure token (type: INGEST)
SPLUNK_ACCESS_TOKEN=CHANGE_THIS_O11Y_ACCESS_TOKEN
# RUM-specific token (type: RUM) — separate from the ingest token
SPLUNK_RUM_TOKEN=CHANGE_THIS_RUM_TOKEN
# Your Splunk realm (visible in the O11y Cloud URL: app.REALM.signalfx.com)
SPLUNK_REALM=us1
# App environment label shown in Splunk APM service map
APP_ENV=production
