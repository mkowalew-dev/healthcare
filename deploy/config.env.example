# ============================================================
# CareConnect EHR — Deployment Configuration
#
# Copy this file to config.env and fill in all values before
# running aws-deploy.sh.
#
#   cp deploy/config.env.example deploy/config.env
#   vi deploy/config.env
#   bash deploy/aws-deploy.sh init all
#
# IMPORTANT: Never commit config.env — it contains secrets.
#            config.env is already in .gitignore.
# ============================================================

# ── SSH access — EC2 (cloud VMs) ────────────────────────────
# IAM key pair created during EC2 launch.
SSH_USER=ubuntu
SSH_KEY=~/.ssh/id_rsa        # path to RSA private key file (.pem or converted)

# ── SSH access — PACS VM (VM5, local) ───────────────────────
# Separate credentials for VM5 — may differ from EC2 key pair.
# Falls back to SSH_USER / SSH_KEY above if not set.
PACS_SSH_USER=ubuntu
PACS_SSH_KEY=~/.ssh/id_rsa   # path to private key for VM5

# ── Web tier — us-east-2 (primary region) ─────────────────────
# VM1s in us-east-2. Comma-separated for multiple instances.
# Find public IPs in: EC2 Console → Instances → Public IPv4 address
FRONTEND_PUBLIC_IPS_USE2="1.2.3.10"          # VM1s: React + BFF + Nginx (use2)
FRONTEND_PRIVATE_IPS_USE2="10.0.1.10"        # VPC-internal IPs (use2)
FRONTEND_ALB_DNS_USE2=careconnect-frontend-use2-1234567890.us-east-2.elb.amazonaws.com

# ── Web tier — us-west-1 (secondary region) ───────────────────
# VM1s in us-west-1. Identical app config — all Nginx instances proxy to
# the same API ALB in us-east-2 (web-only multi-region; API stays in use2).
FRONTEND_PUBLIC_IPS_UW1="2.3.4.10"           # VM1s: React + BFF + Nginx (uw1)
FRONTEND_PRIVATE_IPS_UW1="10.1.1.10"         # VPC-internal IPs (uw1)
FRONTEND_ALB_DNS_UW1=careconnect-frontend-uw1-1234567890.us-west-1.elb.amazonaws.com

# ── AWS Global Accelerator ─────────────────────────────────────
# Static anycast DNS fronting both regional ALBs.
# Route 53 A-alias records for both subdomains → GLOBAL_ACCELERATOR_DNS
#   - Endpoint group us-east-2: FRONTEND_ALB_DNS_USE2 (weight 100, health /ping)
#   - Endpoint group us-west-1: FRONTEND_ALB_DNS_UW1  (weight 100, health /ping)
# GA routes each user to the nearest healthy region automatically.
GLOBAL_ACCELERATOR_DNS=xxxxxxxxxxxxxxxx.awsglobalaccelerator.com

# ── API tier — public IPs (SSH / rsync from deployment machine) ─
# API lives in us-east-2 only (web-only multi-region; single API region).
API_PUBLIC_IPS="1.2.3.20"                    # VM2s: Node.js API + PM2

# ── Single-instance VMs ────────────────────────────────────────
DB_PUBLIC_IP=1.2.3.30                         # VM3: PostgreSQL 17
MOCK_PUBLIC_IP=1.2.3.40                       # VM4: Mock external services

# ── API tier — private IPs (VPC internal, service-to-service) ─
# Comma-separated list — must match the order of API_PUBLIC_IPS.
# Written into Nginx upstream block on each web VM (both regions).
API_PRIVATE_IPS="10.0.1.20"

# ── Single-instance VMs (private) ─────────────────────────────
MOCK_PRIVATE_IP=10.0.1.40

# ── AWS Application Load Balancers ────────────────────────────
#
# FRONTEND_ALB_DNS_USE2 / _UW1  Internet-facing ALBs in each region.
#   Each ALB:
#   - Listener: HTTPS :443 with ACM wildcard cert for *.pseudo-co.com
#   - Listener rules: both subdomains → same target group (VM1s :80 in that region)
#   - HTTP :80 → redirect to HTTPS
#   - Health check: GET /ping
#   Both ALBs are registered as endpoints in the Global Accelerator above.
#   Do NOT point Route 53 directly at the ALBs — point at GLOBAL_ACCELERATOR_DNS.
#
# API_ALB_DNS  Internal ALB in front of VM2 (API tier, us-east-2 only).
#   - Scheme: internal (not internet-facing)
#   - Listener: HTTP :3001
#   - Health check: GET /health on port 3001
#   - Target group: all API_PRIVATE_IPS on port 3001
#   - Nginx on all VM1s (both regions) proxies /api/* and /fhir/* to this DNS name
#   - VM2 Security Group allows inbound :3001 from both VPC CIDRs
API_ALB_DNS=careconnect-api-alb-internal-1234567890.us-east-2.elb.amazonaws.com

# ── Public portal hostnames ────────────────────────────────────
# Two subdomains — both resolve to GLOBAL_ACCELERATOR_DNS.
# DNS records (Route 53):
#   careconnect.pseudo-co.com  A alias → GLOBAL_ACCELERATOR_DNS
#   mychart.pseudo-co.com      A alias → GLOBAL_ACCELERATOR_DNS
#
# CLINICAL_HOST  Provider and admin clinical workspace
#                (CareConnect EHR — providers, schedulers, admins)
# PATIENT_HOST   Patient self-service portal
#                (MyChart — patients view results, book appointments, message providers)
#
# Both hostnames are baked into the React bundles at build time.
# Cross-portal redirect fires automatically: a patient who lands on
# the clinical portal is redirected to mychart.pseudo-co.com, and vice versa.
CLINICAL_HOST=careconnect.pseudo-co.com
PATIENT_HOST=mychart.pseudo-co.com

# ── Database connectivity ──────────────────────────────────────
# DB_HOST  PostgreSQL hostname written into the API's DATABASE_URL.
#          Self-managed VM: private IP of VM3 (e.g. 10.0.1.30)
#          RDS: endpoint FQDN (careconnect-db.xxxx.us-east-2.rds.amazonaws.com)
#          Using a hostname (not a raw IP) gives a named node in Splunk APM.
DB_HOST=10.0.1.30

# API base URL baked into the React bundle at build time.
# Leave empty (recommended) — Nginx on VM1 proxies /api/* to VM2 using the
# private IP, so the browser always talks to the same origin.
API_URL=

# ── Database credentials ─────────────────────────────────────
DB_NAME=careconnect
DB_USER=careconnect
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD    # min 20 chars recommended

# ── JWT secret ───────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_THIS_JWT_SECRET

# ── App version tag ──────────────────────────────────────────
APP_VERSION=1.0.0
APP_ENV=production

# ── AI Assistant (Claude / Anthropic) ───────────────────────
# Get your key from: console.anthropic.com → API Keys
# Leave blank to disable the AI Assistant (app still runs)
ANTHROPIC_API_KEY=

# ── Splunk Observability Cloud ───────────────────────────────
# Get tokens from: Splunk O11y Cloud → Settings → Access Tokens
SPLUNK_ACCESS_TOKEN=CHANGE_THIS_O11Y_ACCESS_TOKEN   # type: INGEST
SPLUNK_RUM_TOKEN=CHANGE_THIS_RUM_TOKEN               # type: RUM (separate token)
SPLUNK_REALM=us1                                     # us0, us1, eu0, ap0, etc.

# ── Splunk Platform (on-prem / customer-hosted instance) ────
# Structured logs are forwarded here via the OTel Collector.
# HEC URL format: https://<splunk-host>:8088/services/collector/event
SPLUNK_PLATFORM_HEC_URL=https://splunk.internal.example.com:8088/services/collector/event
SPLUNK_PLATFORM_HEC_TOKEN=CHANGE_THIS_PLATFORM_HEC_TOKEN

# ── BFF (Backend for Frontend) ───────────────────────────────
# Port the BFF listens on (Nginx proxies /bff/* → VM1:BFF_PORT internally).
BFF_PORT=3003

# ── Mock External Services (VM4) ─────────────────────────────
MOCK_PORT=3002

# Per-service simulated latency (milliseconds).
# Values reflect realistic geographic distances from an EHR to each SaaS.
SURESCRIPTS_LATENCY_MS=180
SURESCRIPTS_LATENCY_JITTER=60
SURESCRIPTS_REGION="us-east-1 (Scottsdale, AZ)"

QUEST_LATENCY_MS=240
QUEST_LATENCY_JITTER=80
QUEST_REGION="us-east-1 (Secaucus, NJ)"

LABCORP_LATENCY_MS=310
LABCORP_LATENCY_JITTER=100
LABCORP_REGION="us-east-2 (Burlington, NC)"

TWILIO_LATENCY_MS=120
TWILIO_LATENCY_JITTER=40
TWILIO_REGION="us-west-2 (San Francisco, CA)"

SENDGRID_LATENCY_MS=95
SENDGRID_LATENCY_JITTER=30
SENDGRID_REGION="us-west-1 (Redwood City, CA)"

# ── Lab Result Simulator ─────────────────────────────────────
# Background job on VM2 that results pending lab orders with synthetic values.
# LAB_RESULT_INTERVAL_MS  how often the batch runs (default: 15 min)
# LAB_MIN_AGE_MS          minimum order age before it gets resulted
# Set LAB_MIN_AGE_MS=60000 for fast turnaround during live demos.
LAB_RESULT_INTERVAL_MS=900000
LAB_MIN_AGE_MS=900000

# ── MyChart Scheduled Failure Injection ──────────────────────
# Injects daily patient-portal failures to showcase ThousandEyes
# synthetic alerting and Splunk APM distributed trace analysis.
# Affected services: labs, medications, appointments, messages, bills.
# Health endpoints (/health) are always exempted — PM2 stays green.
#
# Failure types:
#   api  Returns HTTP 503 immediately. Simulates upstream EHR integration down.
#        ThousandEyes: HTTP synthetic test fails with 503.
#        Splunk APM: mychart.failure.api span on each affected service.
#
#   db   Holds the connection for 8–12 s then returns HTTP 503. Simulates
#        PostgreSQL connection pool exhaustion / query timeout.
#        ThousandEyes: response-time alert fires first, then 503 (two-phase signal).
#        Splunk APM: long mychart.failure.db spans; red service-map edges.
#
# Deploy changes: bash deploy/aws-deploy.sh update api
# To disable: set MYCHART_FAILURE_ENABLED= (empty) and re-deploy.
#
# MYCHART_FAILURE_ENABLED=true
# MYCHART_FAILURE_TYPE=api
# MYCHART_FAILURE_HOUR=14
# MYCHART_FAILURE_MINUTE=0
# MYCHART_FAILURE_DURATION=15

# ── PACS — Radiology Imaging System (local) ──────────────────
#
# The PACS system runs locally on the demo laptop (not in AWS).
# Managed via:  bash deploy/local-deploy.sh init all
#
# PACS_PUBLIC_IP     Public IP address of VM5 (the PACS server).
#                    local-deploy.sh SSHes to this IP to deploy and manage the PACS.
#                    ThousandEyes Enterprise Agent uses this IP as its test target.
#                    Use 127.0.0.1 only when running local-deploy.sh directly on VM5.
#
# PACS_SERVER_PORT   DICOMweb API server port (default: 3021)
# PACS_VIEWER_PORT   Cornerstone.js radiology viewer port (default: 5174)
# PACS_JWT_SECRET    JWT signing secret — generate: openssl rand -hex 32
#
# ThousandEyes demo: raise PACS_IMAGE_LATENCY_MS to simulate a degraded
# WAN path between the radiologist workstation and the PACS server.
# ThousandEyes catches the degradation; radiologists feel the slow image loads.
# Live control:  bash deploy/local-deploy.sh latency set 1500 300
#               bash deploy/local-deploy.sh latency clear
PACS_PUBLIC_IP=127.0.0.1
PACS_HOST=pacs.pseudo-co.com      # custom hostname — adds to CORS_ORIGIN and VITE_PACS_URL
PACS_SERVER_PORT=3021
PACS_VIEWER_PORT=5174
PACS_JWT_SECRET=CHANGE_THIS_PACS_JWT_SECRET
PACS_IMAGE_LATENCY_MS=0
PACS_IMAGE_LATENCY_JITTER_MS=0
