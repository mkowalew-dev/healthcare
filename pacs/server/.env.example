PORT=3021
NODE_ENV=development
APP_VERSION=1.0.0

# JWT — must match PACS viewer's VITE_PACS_JWT_SECRET if viewer does server-side validation
JWT_SECRET=pacs-demo-secret-change-me-in-production

# CORS — comma-separated origins allowed to call this server
CORS_ORIGIN=http://localhost:5174

# Directory of .dcm files (relative to server root, or absolute path)
STUDIES_DIR=./studies

# Public URL used to build wadouri:// image IDs returned to the viewer
# Leave empty for localhost dev; set to public hostname in production
PACS_PUBLIC_URL=

# ── Simulated image latency (ThousandEyes demo) ──────────────────────────────
# Raise IMAGE_LATENCY_MS to emulate a congested WAN between the radiologist
# workstation and the PACS server — ThousandEyes shows the degradation before
# radiologists feel the impact.
IMAGE_LATENCY_MS=0
IMAGE_LATENCY_JITTER_MS=0

# ── Splunk Observability Cloud (APM) ────────────────────────────────────────
SPLUNK_ACCESS_TOKEN=
SPLUNK_REALM=us1
OTEL_SERVICE_NAME=careconnect-pacs
# Use a local OTel collector instead of direct Splunk ingest:
OTEL_EXPORTER_OTLP_ENDPOINT=
