# ─────────────────────────────────────────────────────────────────────────────
# CareConnect Synthetic Test Configuration
# Copy this file to .env and fill in values for the Windows test machine.
# ─────────────────────────────────────────────────────────────────────────────

# -- Application URLs ---------------------------------------------------------
CARECONNECT_URL=https://careconnect.pseudo-co.com
MYCHART_URL=https://mychart.pseudo-co.com
PACS_URL=http://pacs.pseudo-co.com:5174

# -- Credentials --------------------------------------------------------------
DEMO_PASSWORD=Demo123!

# -- Chrome profile -----------------------------------------------------------
#
# CHROME_USER_DATA_DIR  - the User Data parent directory (NOT the profile folder)
# CHROME_PROFILE_DIR    - the profile subfolder inside User Data (default: Profile 1)
# CHROME_DEBUG_PORT     - remote-debugging-port Chrome will listen on (default: 9222)
#
# Chrome is launched externally by run-tests.ps1 so Playwright never adds its
# --enable-automation flag.  This lets the ThousandEyes Endpoint Agent extension
# report real browser metrics.  Set CHROME_USER_DATA_DIR to the directory that
# contains the profile where the TE extension is authenticated.
#
# Example for a machine where the signed-in profile is "Profile 1":
#   CHROME_USER_DATA_DIR=C:\Users\atl-user\AppData\Local\Google\Chrome\User Data
#   CHROME_PROFILE_DIR=Profile 1
#
CHROME_USER_DATA_DIR=C:\Users\atl-user\AppData\Local\Google\Chrome\User Data
CHROME_PROFILE_DIR=Profile 1
CHROME_DEBUG_PORT=9222
