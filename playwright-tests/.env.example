# ─────────────────────────────────────────────────────────────────────────────
# CareConnect Synthetic Test Configuration
# Copy this file to .env and fill in values for the Windows test machine.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application URLs ─────────────────────────────────────────────────────────
CARECONNECT_URL=https://careconnect.pseudo-co.com
MYCHART_URL=https://mychart.pseudo-co.com
PACS_URL=http://pacs.pseudo-co.com:5174

# ── Credentials ──────────────────────────────────────────────────────────────
# All three apps use the same hardcoded demo user (dr.chen@careconnect.demo).
# Only the password is entered by the test; the email field is read-only in the UI.
DEMO_PASSWORD=Demo123!

# ── ThousandEyes Chrome Extension ────────────────────────────────────────────
# Full path to the unpacked ThousandEyes extension folder on the Windows machine.
# The extension must be the DIRECTORY that contains manifest.json (not a .crx file).
#
# Typical locations:
#   Enterprise Agent bundled extension:
#     C:\Program Files\ThousandEyes Enterprise Agent\chrome-extension
#   Manually installed via Chrome Web Store (find your extension ID in chrome://extensions):
#     C:\Users\<username>\AppData\Local\Google\Chrome\User Data\Default\Extensions\<ID>\<version>
#
# Leave blank to run without the extension (useful for local development on macOS/Linux).
TE_EXTENSION_PATH=C:\Program Files\ThousandEyes Enterprise Agent\chrome-extension

# ── Chrome profile ────────────────────────────────────────────────────────────
# Playwright uses a temporary profile per test run by default.
# Set this if you need a persistent profile (e.g., to avoid CAPTCHA challenges).
# CHROME_USER_DATA_DIR=C:\playwright-chrome-profile
