# ─────────────────────────────────────────────────────────────────────────────
# CareConnect Synthetic Test Configuration
# Copy this file to .env and fill in values for the Windows test machine.
# ─────────────────────────────────────────────────────────────────────────────

# -- Application URLs ---------------------------------------------------------
CARECONNECT_URL=https://careconnect.pseudo-co.com
MYCHART_URL=https://mychart.pseudo-co.com
PACS_URL=http://pacs.pseudo-co.com:5174

# -- Credentials --------------------------------------------------------------
DEMO_PASSWORD=Demo123!

# -- ThousandEyes Chrome Extension --------------------------------------------
#
# REQUIRED for real browser stats to appear in ThousandEyes.
#
# Set CHROME_PROFILE_PATH to the exact value shown under "Profile Path" in
# chrome://version/ for the profile where the TE extension is installed and
# signed in.  Paste the path as-is - spaces are handled automatically.
#
# NOTE: Chrome must be fully closed before running the tests.  Chrome will not
# let two processes open the same profile at the same time.
#
CHROME_PROFILE_PATH=C:\Users\atl-user\AppData\Local\Google\Chrome\User Data\Profile 1

# -- TE_EXTENSION_PATH (alternative, no auth) ---------------------------------
# Only use this if you cannot use an existing profile.  The extension will load
# but will NOT be authenticated, so ThousandEyes will not receive browser stats.
# TE_EXTENSION_PATH=C:\Program Files\ThousandEyes Enterprise Agent\chrome-extension
