# ─────────────────────────────────────────────────────────────────────────────
# CareConnect Synthetic Test Configuration
# Copy this file to .env and fill in values for the Windows test machine.
# ─────────────────────────────────────────────────────────────────────────────

# -- Application URLs ---------------------------------------------------------
CARECONNECT_URL=https://careconnect.pseudo-co.com
MYCHART_URL=https://mychart.pseudo-co.com
PACS_URL=http://pacs.pseudo-co.com:5174

# -- Credentials --------------------------------------------------------------
DEMO_PASSWORD=Demo123!

# -- ThousandEyes Chrome Extension --------------------------------------------
#
# REQUIRED for real browser stats to appear in ThousandEyes.
#
# CHROME_USER_DATA_DIR  - parent folder that contains all Chrome profiles.
#                         Found at chrome://version/ -> "Profile Path", then
#                         take the directory one level UP from the profile name.
#
# CHROME_PROFILE_DIRECTORY - the profile subfolder name where the TE extension
#                         is installed and signed in.  This is the last segment
#                         of the "Profile Path" shown in chrome://version/.
#
# Example: if chrome://version/ shows
#   Profile Path: C:\Users\atl-user\AppData\Local\Google\Chrome\User Data\Profile 1
# then set:
#   CHROME_USER_DATA_DIR=C:\Users\atl-user\AppData\Local\Google\Chrome\User Data
#   CHROME_PROFILE_DIRECTORY=Profile 1
#
# NOTE: Close Chrome before running the tests - two processes cannot share the
# same profile at the same time.
#
CHROME_USER_DATA_DIR=C:\Users\atl-user\AppData\Local\Google\Chrome\User Data
CHROME_PROFILE_DIRECTORY=Profile 1

# -- TE_EXTENSION_PATH (alternative, no auth) ---------------------------------
# Only use this if you cannot use an existing profile.  The extension will load
# but will NOT be authenticated, so ThousandEyes will not receive browser stats.
# TE_EXTENSION_PATH=C:\Program Files\ThousandEyes Enterprise Agent\chrome-extension
