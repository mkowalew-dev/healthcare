# ─────────────────────────────────────────────────────────────────────────────
# CareConnect Synthetic Test Configuration
# Copy this file to .env and fill in values for the Windows test machine.
# ─────────────────────────────────────────────────────────────────────────────

# -- Application URLs ---------------------------------------------------------
CARECONNECT_URL=https://careconnect.pseudo-co.com
MYCHART_URL=https://mychart.pseudo-co.com
PACS_URL=http://pacs.pseudo-co.com:5174

# -- Credentials --------------------------------------------------------------
DEMO_PASSWORD=Demo123!

# -- Chrome profile for ThousandEyes ------------------------------------------
#
# A dedicated directory used only by these tests.  Do NOT point this at your
# real Chrome User Data folder - that causes session restore locks and
# singleton conflicts that prevent Playwright from navigating.
#
# If the ThousandEyes extension is policy-managed (Extensions folder in your
# real profile is empty), Chrome will install it automatically into this
# directory the first time it opens - no extra config needed.
#
# If the extension is NOT policy-managed, also set TE_EXTENSION_PATH (see below).
#
CHROME_USER_DATA_DIR=C:\playwright-te-profile

# -- TE_EXTENSION_PATH (only needed if extension is NOT policy-managed) -------
# Set this to the folder containing the extension manifest.json.
# Leave commented out if the extension installs automatically via policy.
# TE_EXTENSION_PATH=C:\path\to\thousandeyes-extension
