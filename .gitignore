# ============================================================
# CareConnect EHR — .gitignore
# ============================================================

# ── Secrets & environment files ─────────────────────────────
# Never commit real credentials. Use *.example files instead.
.env
.env.local
.env.*.local
backend/.env
deploy/config.env

# ── Node.js dependencies ─────────────────────────────────────
node_modules/
.npm/
.pnp
.pnp.js

# ── Build output ─────────────────────────────────────────────
frontend/dist/
frontend/build/
backend/dist/

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Vite / TypeScript ─────────────────────────────────────────
*.tsbuildinfo
frontend/.vite/

# ── OS artifacts ─────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Editor / IDE ─────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# ── Deployment artifacts ─────────────────────────────────────
# Build tarballs or staging dirs that may appear during deploy
/tmp/
*.tar.gz
*.zip

# ── Testing ──────────────────────────────────────────────────
coverage/
.nyc_output/

# ── PM2 ──────────────────────────────────────────────────────
.pm2/
frontend/node_modules
CLAUDE.md
HANDOFF.md
