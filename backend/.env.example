NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://careconnect:careconnect_dev@localhost:5432/careconnect
JWT_SECRET=careconnect-demo-jwt-secret-2024
CORS_ORIGIN=http://localhost:5173

# AI Assistant — get key from console.anthropic.com
ANTHROPIC_API_KEY=

# ── Mock External Services (port 3002) ────────────────────────────────────────
# Run: npm run mock
# Leave these pointing at localhost for local dev.
# For a multi-VM ThousandEyes demo, set them to the VM running mock-services.js
MOCK_PORT=3002

SURESCRIPTS_URL=http://localhost:3002/surescripts
QUEST_LIS_URL=http://localhost:3002/quest
LABCORP_LIS_URL=http://localhost:3002/labcorp
TWILIO_API_URL=http://localhost:3002/twilio
SENDGRID_API_URL=http://localhost:3002/sendgrid

# ── Mock Latency Simulation (milliseconds) ───────────────────────────────────
# Base latency per service — jitter is applied on top (±jitterMs)
SURESCRIPTS_LATENCY_MS=180
SURESCRIPTS_LATENCY_JITTER=60
SURESCRIPTS_REGION=us-east-1 (Scottsdale, AZ)

QUEST_LATENCY_MS=240
QUEST_LATENCY_JITTER=80
QUEST_REGION=us-east-1 (Secaucus, NJ)

LABCORP_LATENCY_MS=310
LABCORP_LATENCY_JITTER=100
LABCORP_REGION=us-east-2 (Burlington, NC)

TWILIO_LATENCY_MS=120
TWILIO_LATENCY_JITTER=40
TWILIO_REGION=us-west-2 (San Francisco, CA)

SENDGRID_LATENCY_MS=95
SENDGRID_LATENCY_JITTER=30
SENDGRID_REGION=us-west-1 (Redwood City, CA)

# ── Mock Chaos / Failure Simulation (0.0 = never, 1.0 = always) ──────────────
# Uncomment and raise these during a demo to simulate an outage
# SURESCRIPTS_FAILURE_RATE=0.5
# QUEST_FAILURE_RATE=0.3
# TWILIO_FAILURE_RATE=0.5
# SENDGRID_FAILURE_RATE=0.2
# TWILIO_TIMEOUT_RATE=0.1
